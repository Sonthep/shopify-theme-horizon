{% assign bid = block.id | replace: '_', '' | downcase %}

{% style %}
  .spec-table-{{ bid }} {
    width: 100%;
    max-width: 100%;
  }

  .spec-table__heading-{{ bid }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 12px;
    color: currentColor;
  }

  .spec-table__wrapper-{{ bid }} {
    overflow-x: auto;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .spec-table__table-{{ bid }} {
    width: 100%;
    border-collapse: collapse;
    font-size: {{ block.settings.font_size }}px;
  }

  .spec-table__table-{{ bid }} tr {
    border-bottom: 1px solid {{ block.settings.row_divider_color }};
  }

  .spec-table__table-{{ bid }} tr:last-child {
    border-bottom: none;
  }

  .spec-table__table-{{ bid }} tr:nth-child(even) {
    background-color: {{ block.settings.stripe_color }};
  }

  .spec-table__table-{{ bid }} th {
    padding: {{ block.settings.cell_padding }}px {{ block.settings.cell_padding | times: 1.5 | round }}px;
    text-align: left;
    font-weight: 600;
    font-size: {{ block.settings.font_size | minus: 1 }}px;
    background-color: {{ block.settings.header_bg }};
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .spec-table__table-{{ bid }} td {
    padding: {{ block.settings.cell_padding }}px {{ block.settings.cell_padding | times: 1.5 | round }}px;
    vertical-align: top;
    color: currentColor;
  }

  .spec-table__label-{{ bid }} {
    font-weight: 500;
    width: {{ block.settings.label_width }}%;
    color: {{ block.settings.label_color }};
  }

  @media screen and (max-width: 749px) {
    .spec-table__table-{{ bid }} th,
    .spec-table__table-{{ bid }} td {
      padding: 8px 10px;
      font-size: {{ block.settings.font_size | minus: 1 }}px;
    }
  }
{% endstyle %}

<div class="spec-table-{{ bid }} spacing-style" style="{% render 'spacing-style', settings: block.settings %}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="spec-table__heading-{{ bid }}">{{ block.settings.heading | escape }}</h2>
  {% endif %}

  <div class="spec-table__wrapper-{{ bid }}">
    <table class="spec-table__table-{{ bid }}">
      {% if block.settings.show_header %}
        <thead>
          <tr>
            <th class="spec-table__label-{{ bid }}">{{ block.settings.col1_header | default: 'Specification' | escape }}</th>
            <th>{{ block.settings.col2_header | default: 'Value' | escape }}</th>
          </tr>
        </thead>
      {% endif %}
      <tbody>
        {% for i in (1..15) %}
          {% liquid
            assign label_key = 'row_label_' | append: i
            assign value_key = 'row_value_' | append: i
            assign label = block.settings[label_key]
            assign value = block.settings[value_key]
          %}
          {% if label != blank or value != blank %}
            <tr>
              <td class="spec-table__label-{{ bid }}">{{ label | escape }}</td>
              <td>{{ value | escape }}</td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

