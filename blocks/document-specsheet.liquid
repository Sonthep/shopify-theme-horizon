{% doc %}
  @prompt
    Create a professional document download section that displays downloadable PDF files in a clean table format. The section should:
    
    - Display a table with three columns: File type, File name, and Action (download button)
    - Support adding multiple PDF files with customizable file names (e.g., "Spec Sheet", "Installation Manual", "Parts Manual")
    - Each row shows "PDF" as file type, custom file name, and a "Download" link/button
    - Table should have a clean header row with labels: "File type", "File name", "Action"
    - Include a customizable section heading (default: "Download" or "Documents")
    - Allow merchants to upload PDF files and set custom display names for each
    - Download links should be styled consistently (blue/teal color as shown)
    - Table should be responsive and mobile-friendly
    - Use clean borders and spacing for professional B2B appearance
    - Support reordering of files
    - Optional: Show file size next to file name
    - Maintain accessibility with proper table markup
    
    The design should be clean, minimal, and professional - suitable for technical documentation and product manuals for commercial equipment.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-doc-download-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-doc-download__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-doc-download__table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    border: {{ block.settings.table_border_width }}px solid {{ block.settings.table_border_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
  }

  .ai-doc-download__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
  }

  .ai-doc-download__table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
  }

  .ai-doc-download__table-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: left;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.header_border_width }}px solid {{ block.settings.table_border_color }};
  }

  .ai-doc-download__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    font-size: {{ block.settings.cell_font_size }}px;
    color: {{ block.settings.cell_text_color }};
    border-bottom: {{ block.settings.row_border_width }}px solid {{ block.settings.row_border_color }};
  }

  .ai-doc-download__table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-doc-download__table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_background }};
  }

  .ai-doc-download__file-type-{{ ai_gen_id }} {
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.file_type_color }};
  }

  .ai-doc-download__file-name-{{ ai_gen_id }} {
    font-weight: 500;
  }

  .ai-doc-download__file-size-{{ ai_gen_id }} {
    font-size: {{ block.settings.file_size_font_size }}px;
    color: {{ block.settings.file_size_color }};
    margin-left: 8px;
  }

  .ai-doc-download__download-link-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .ai-doc-download__download-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  .ai-doc-download__empty-state-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: {{ block.settings.empty_state_color }};
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-doc-download__table-{{ ai_gen_id }} th,
    .ai-doc-download__table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.75 }}px;
      font-size: {{ block.settings.cell_font_size | minus: 2 }}px;
    }

    .ai-doc-download__table-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | minus: 2 }}px;
    }

    .ai-doc-download__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}
<div class="ai-doc-download-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-doc-download__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% liquid
    assign has_files = false
    assign has_metafield_spec = false

    if block.settings.use_metafield_spec and product.metafields.custom.spec_sheet != blank
      assign has_metafield_spec = true
      assign has_files = true
    endif

    for i in (1..10)
      assign file_key = 'file_' | append: i
      assign file = block.settings[file_key]
      if file != blank
        assign has_files = true
        break
      endif
    endfor
  %}

  {% if has_files %}
    <div class="ai-doc-download__table-wrapper-{{ ai_gen_id }}">
      <table class="ai-doc-download__table-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>{{ block.settings.column_1_label }}</th>
            <th>{{ block.settings.column_2_label }}</th>
            <th>{{ block.settings.column_3_label }}</th>
          </tr>
        </thead>
        <tbody>
          {% if has_metafield_spec %}
            <tr>
              <td>
                <span class="ai-doc-download__file-type-{{ ai_gen_id }}">PDF</span>
              </td>
              <td>
                <span class="ai-doc-download__file-name-{{ ai_gen_id }}">
                  {{ block.settings.metafield_spec_label | default: 'Spec Sheet' }}
                </span>
              </td>
              <td>
                <a
                  href="{{ product.metafields.custom.spec_sheet.value.url }}"
                  class="ai-doc-download__download-link-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                >
                  {{ block.settings.download_label }}
                </a>
              </td>
            </tr>
          {% endif %}

          {% for i in (1..10) %}
            {% liquid
              assign file_key = 'file_' | append: i
              assign name_key = 'file_name_' | append: i
              assign size_key = 'file_size_' | append: i
              
              assign file = block.settings[file_key]
              assign file_name = block.settings[name_key]
              assign file_size = block.settings[size_key]
            %}

            {% if file != blank %}
              <tr>
                <td>
                  <span class="ai-doc-download__file-type-{{ ai_gen_id }}">PDF</span>
                </td>
                <td>
                  <span class="ai-doc-download__file-name-{{ ai_gen_id }}">
                    {% if file_name != blank %}
                      {{ file_name }}
                    {% else %}
                      Document {{ i }}
                    {% endif %}
                  </span>
                  {% if block.settings.show_file_size and file_size != blank %}
                    <span class="ai-doc-download__file-size-{{ ai_gen_id }}">({{ file_size }})</span>
                  {% endif %}
                </td>
                <td>
                  <a 
                    href="{{ file }}" 
                    class="ai-doc-download__download-link-{{ ai_gen_id }}"
                    target="_blank"
                    rel="noopener"
                  >
                    {{ block.settings.download_label }}
                  </a>
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <div class="ai-doc-download__table-wrapper-{{ ai_gen_id }}">
      <div class="ai-doc-download__empty-state-{{ ai_gen_id }}">
        Next, add PDF files to display in the table
      </div>
    </div>
  {% endif %}
</div>


