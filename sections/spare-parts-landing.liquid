{% comment %} ============================================================
  COMMERCIAL KITCHEN SPARE PARTS — Landing Page Section
  Sections: Hero · Categories · Brands · Featured Parts
            Problem-Solution · How It Works · Final CTA
  ============================================================ {% endcomment %}

<style>
/* ──────────────────────────────────────────────────────────
   CSS CUSTOM PROPERTIES
────────────────────────────────────────────────────────── */
.spl-root {
  --spl-accent:       #22c55e;
  --spl-accent-dark:  #16a34a;
  --spl-accent-light: #dcfce7;
  --spl-bg:           #ffffff;
  --spl-bg-alt:       #f8fafc;
  --spl-bg-muted:     #f1f5f9;
  --spl-border:       #e2e8f0;
  --spl-text:         #0f172a;
  --spl-text-muted:   #64748b;
  --spl-text-light:   #94a3b8;
  --spl-radius:       12px;
  --spl-radius-lg:    20px;
  --spl-shadow-sm:    0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
  --spl-shadow:       0 4px 16px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
  --spl-shadow-md:    0 8px 32px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.06);
  --spl-shadow-lg:    0 20px 60px rgba(0,0,0,.12), 0 4px 16px rgba(0,0,0,.06);
  --spl-transition:   0.22s cubic-bezier(.4,0,.2,1);
  --spl-font:         'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-family: var(--spl-font);
  color: var(--spl-text);
  background: var(--spl-bg);
}

/* ──────────────────────────────────────────────────────────
   SHARED UTILITIES
────────────────────────────────────────────────────────── */
.spl-container {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 4vw, 48px);
}

.spl-section {
  padding-block: clamp(56px, 8vw, 96px);
}

.spl-section--alt {
  background: var(--spl-bg-alt);
}

.spl-section--muted {
  background: var(--spl-bg-muted);
}

.spl-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--spl-accent-dark);
  background: var(--spl-accent-light);
  padding: 4px 12px;
  border-radius: 99px;
  margin-bottom: 14px;
}

.spl-heading {
  font-size: clamp(24px, 3.5vw, 38px);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -.02em;
  color: var(--spl-text);
  margin: 0 0 8px;
}

.spl-subheading {
  font-size: clamp(15px, 1.8vw, 17px);
  color: var(--spl-text-muted);
  line-height: 1.6;
  margin: 0 0 40px;
  max-width: 540px;
}

.spl-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  text-decoration: none;
  transition: transform var(--spl-transition), box-shadow var(--spl-transition), background var(--spl-transition);
  white-space: nowrap;
}

.spl-btn--primary {
  background: var(--spl-accent);
  color: #fff;
  box-shadow: 0 4px 14px rgba(34,197,94,.3);
}
.spl-btn--primary:hover {
  background: var(--spl-accent-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(34,197,94,.35);
}

.spl-btn--outline {
  background: transparent;
  color: var(--spl-text);
  border: 1.5px solid var(--spl-border);
  box-shadow: var(--spl-shadow-sm);
}
.spl-btn--outline:hover {
  border-color: var(--spl-accent);
  color: var(--spl-accent-dark);
  transform: translateY(-2px);
  box-shadow: var(--spl-shadow);
}

/* ──────────────────────────────────────────────────────────
   1. HERO SECTION
────────────────────────────────────────────────────────── */
.spl-hero {
  position: relative;
  background: linear-gradient(160deg, #f8fafc 0%, #ffffff 60%, #f0fdf4 100%);
  padding-block: clamp(64px, 10vw, 120px) clamp(56px, 8vw, 96px);
  overflow: hidden;
}

.spl-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(34,197,94,.07) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(34,197,94,.05) 0%, transparent 40%);
  pointer-events: none;
}

/* Grid dot pattern */
.spl-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
  background-size: 28px 28px;
  opacity: 0.35;
  pointer-events: none;
}

.spl-hero__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.spl-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--spl-bg);
  border: 1px solid var(--spl-border);
  border-radius: 99px;
  padding: 5px 14px 5px 8px;
  font-size: 12.5px;
  font-weight: 500;
  color: var(--spl-text-muted);
  margin-bottom: 28px;
  box-shadow: var(--spl-shadow-sm);
}

.spl-hero__badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--spl-accent);
  box-shadow: 0 0 0 3px var(--spl-accent-light);
  animation: spl-pulse 2.4s ease-in-out infinite;
}

@keyframes spl-pulse {
  0%, 100% { box-shadow: 0 0 0 3px var(--spl-accent-light); }
  50% { box-shadow: 0 0 0 6px rgba(34,197,94,.15); }
}

.spl-hero__title {
  font-size: clamp(32px, 5.5vw, 60px);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -.03em;
  color: var(--spl-text);
  margin: 0 0 20px;
  max-width: 760px;
}

.spl-hero__title span {
  color: var(--spl-accent-dark);
  position: relative;
}

.spl-hero__subtitle {
  font-size: clamp(15px, 2vw, 18px);
  color: var(--spl-text-muted);
  line-height: 1.65;
  margin: 0 0 48px;
  max-width: 540px;
}

/* Search bar */
.spl-search-wrap {
  width: 100%;
  max-width: 680px;
  margin-bottom: 16px;
}

.spl-search-box {
  display: flex;
  align-items: center;
  background: var(--spl-bg);
  border: 1.5px solid var(--spl-border);
  border-radius: 14px;
  padding: 6px 6px 6px 20px;
  gap: 12px;
  box-shadow: var(--spl-shadow-md);
  transition: border-color var(--spl-transition), box-shadow var(--spl-transition);
}

.spl-search-box:focus-within {
  border-color: var(--spl-accent);
  box-shadow: 0 0 0 4px rgba(34,197,94,.12), var(--spl-shadow-md);
}

.spl-search-icon {
  flex-shrink: 0;
  color: var(--spl-text-light);
}

.spl-search-input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 16px;
  color: var(--spl-text);
  background: transparent;
  font-family: var(--spl-font);
  padding: 10px 0;
}

.spl-search-input::placeholder {
  color: var(--spl-text-light);
}

.spl-search-btn {
  flex-shrink: 0;
  background: var(--spl-accent);
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  font-family: var(--spl-font);
  transition: background var(--spl-transition), transform var(--spl-transition);
  white-space: nowrap;
}

.spl-search-btn:hover {
  background: var(--spl-accent-dark);
  transform: scale(1.02);
}

.spl-search-hint {
  font-size: 13px;
  color: var(--spl-text-light);
  margin-bottom: 36px;
}

.spl-search-hint code {
  background: var(--spl-bg-muted);
  border: 1px solid var(--spl-border);
  border-radius: 5px;
  padding: 1px 6px;
  font-size: 11.5px;
  font-family: var(--spl-font);
  color: var(--spl-text-muted);
}

.spl-hero__cta-group {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
}

/* Hero trust bar */
.spl-hero__trust {
  display: flex;
  align-items: center;
  gap: 24px;
  margin-top: 56px;
  padding-top: 40px;
  border-top: 1px solid var(--spl-border);
  flex-wrap: wrap;
  justify-content: center;
}

.spl-hero__trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13.5px;
  font-weight: 500;
  color: var(--spl-text-muted);
}

.spl-hero__trust-icon {
  width: 30px;
  height: 30px;
  background: var(--spl-accent-light);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--spl-accent-dark);
  flex-shrink: 0;
}

/* ──────────────────────────────────────────────────────────
   2. QUICK CATEGORY GRID
────────────────────────────────────────────────────────── */
.spl-categories__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 40px;
  gap: 16px;
  flex-wrap: wrap;
}

.spl-categories__header .spl-subheading {
  margin-bottom: 0;
}

.spl-view-all {
  font-size: 14px;
  font-weight: 600;
  color: var(--spl-accent-dark);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  white-space: nowrap;
  transition: gap var(--spl-transition);
}
.spl-view-all:hover { gap: 8px; }

.spl-categories__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(168px, 1fr));
  gap: 16px;
}

.spl-cat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  padding: 28px 16px 24px;
  background: var(--spl-bg);
  border: 1.5px solid var(--spl-border);
  border-radius: var(--spl-radius-lg);
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  transition: transform var(--spl-transition), border-color var(--spl-transition), box-shadow var(--spl-transition);
  box-shadow: var(--spl-shadow-sm);
  position: relative;
  overflow: hidden;
}

.spl-cat-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--spl-accent-light) 0%, transparent 60%);
  opacity: 0;
  transition: opacity var(--spl-transition);
}

.spl-cat-card:hover {
  transform: translateY(-4px);
  border-color: var(--spl-accent);
  box-shadow: var(--spl-shadow-md);
}

.spl-cat-card:hover::before { opacity: 1; }

.spl-cat-icon {
  position: relative;
  z-index: 1;
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: var(--spl-bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  transition: background var(--spl-transition), transform var(--spl-transition);
}

.spl-cat-card:hover .spl-cat-icon {
  background: var(--spl-accent-light);
  transform: scale(1.08);
}

.spl-cat-label {
  position: relative;
  z-index: 1;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--spl-text);
  text-align: center;
  line-height: 1.35;
}

.spl-cat-count {
  position: relative;
  z-index: 1;
  font-size: 11.5px;
  color: var(--spl-text-light);
  font-weight: 500;
}

/* ──────────────────────────────────────────────────────────
   3. SEARCH BY BRAND
────────────────────────────────────────────────────────── */
.spl-brands__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  justify-content: center;
  margin-top: 40px;
}

.spl-brand-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--spl-bg);
  border: 1.5px solid var(--spl-border);
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  color: var(--spl-text-muted);
  cursor: pointer;
  text-decoration: none;
  transition: transform var(--spl-transition), border-color var(--spl-transition), color var(--spl-transition), box-shadow var(--spl-transition);
  box-shadow: var(--spl-shadow-sm);
  letter-spacing: .01em;
}

.spl-brand-chip:hover {
  transform: translateY(-2px);
  border-color: var(--spl-accent);
  color: var(--spl-accent-dark);
  box-shadow: var(--spl-shadow);
}

.spl-brand-chip__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--spl-border);
  transition: background var(--spl-transition);
}
.spl-brand-chip:hover .spl-brand-chip__dot {
  background: var(--spl-accent);
}

.spl-brands__cta {
  text-align: center;
  margin-top: 32px;
}

/* ──────────────────────────────────────────────────────────
   4. FEATURED PRODUCTS
────────────────────────────────────────────────────────── */
.spl-products__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 20px;
}

.spl-product-card {
  background: var(--spl-bg);
  border: 1.5px solid var(--spl-border);
  border-radius: var(--spl-radius-lg);
  overflow: hidden;
  transition: transform var(--spl-transition), box-shadow var(--spl-transition);
  box-shadow: var(--spl-shadow-sm);
  display: flex;
  flex-direction: column;
}

.spl-product-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--spl-shadow-lg);
}

.spl-product-card__image {
  position: relative;
  background: var(--spl-bg-muted);
  aspect-ratio: 4/3;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spl-product-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.spl-product-card:hover .spl-product-card__image img {
  transform: scale(1.05);
}

.spl-product-card__image-placeholder {
  font-size: 48px;
  opacity: .4;
}

.spl-badge {
  position: absolute;
  top: 12px;
  right: 12px;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
}

.spl-badge--instock {
  background: var(--spl-accent);
  color: #fff;
}

.spl-badge--limited {
  background: #f59e0b;
  color: #fff;
}

.spl-badge--inquiry {
  background: #64748b;
  color: #fff;
}

.spl-product-card__body {
  padding: 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.spl-product-card__category {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--spl-accent-dark);
}

.spl-product-card__name {
  font-size: 15px;
  font-weight: 700;
  color: var(--spl-text);
  line-height: 1.35;
  margin: 0;
}

.spl-product-card__part-no {
  font-size: 12px;
  color: var(--spl-text-light);
  font-family: 'SFMono-Regular', Consolas, monospace;
  font-weight: 500;
}

.spl-product-card__compat {
  font-size: 12.5px;
  color: var(--spl-text-muted);
  line-height: 1.4;
  margin-top: 4px;
}

.spl-product-card__compat strong {
  color: var(--spl-text);
  font-weight: 600;
}

.spl-product-card__footer {
  padding: 0 20px 20px;
  display: flex;
  gap: 8px;
}

.spl-product-card__footer .spl-btn {
  flex: 1;
  justify-content: center;
  padding: 10px 14px;
  font-size: 13.5px;
}

/* ──────────────────────────────────────────────────────────
   5. PROBLEM–SOLUTION
────────────────────────────────────────────────────────── */
.spl-problems__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 24px;
}

.spl-problem-block {
  background: var(--spl-bg);
  border: 1.5px solid var(--spl-border);
  border-radius: var(--spl-radius-lg);
  padding: 32px 28px;
  box-shadow: var(--spl-shadow-sm);
  transition: transform var(--spl-transition), box-shadow var(--spl-transition);
  position: relative;
  overflow: hidden;
}

.spl-problem-block::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--spl-accent), var(--spl-accent-dark));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform var(--spl-transition);
}

.spl-problem-block:hover { transform: translateY(-3px); box-shadow: var(--spl-shadow-md); }
.spl-problem-block:hover::after { transform: scaleX(1); }

.spl-problem-block__icon {
  font-size: 32px;
  margin-bottom: 18px;
  display: block;
}

.spl-problem-block__problem {
  font-size: 15.5px;
  font-weight: 700;
  color: var(--spl-text);
  margin: 0 0 8px;
}

.spl-problem-block__solution {
  font-size: 14px;
  color: var(--spl-text-muted);
  line-height: 1.6;
  margin: 0 0 18px;
}

.spl-problem-block__link {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--spl-accent-dark);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: gap var(--spl-transition);
}
.spl-problem-block__link:hover { gap: 8px; }

/* ──────────────────────────────────────────────────────────
   6. HOW IT WORKS
────────────────────────────────────────────────────────── */
.spl-how {
  text-align: center;
}

.spl-how__steps {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  align-items: start;
  gap: 0;
  margin-top: 56px;
}

@media (max-width: 700px) {
  .spl-how__steps {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .spl-how__connector { display: none; }
}

.spl-how__step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18px;
  padding: 16px;
}

.spl-how__step-bubble {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--spl-accent-light), #bbf7d0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  box-shadow: 0 4px 16px rgba(34,197,94,.2);
}

.spl-how__step-number {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--spl-accent-dark);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2.5px solid var(--spl-bg);
}

.spl-how__step-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--spl-text);
  margin: 0;
}

.spl-how__step-desc {
  font-size: 13.5px;
  color: var(--spl-text-muted);
  line-height: 1.6;
  margin: 0;
  max-width: 200px;
}

.spl-how__connector {
  display: flex;
  align-items: flex-start;
  padding-top: 40px;
}

.spl-how__connector-line {
  width: 52px;
  height: 2px;
  background: repeating-linear-gradient(
    90deg,
    var(--spl-accent) 0,
    var(--spl-accent) 6px,
    transparent 6px,
    transparent 12px
  );
  position: relative;
}

.spl-how__connector-arrow {
  margin-left: -1px;
  color: var(--spl-accent);
}

/* ──────────────────────────────────────────────────────────
   7. FINAL CTA SECTION
────────────────────────────────────────────────────────── */
.spl-cta-section {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #064e3b 100%);
  padding-block: clamp(64px, 10vw, 100px);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.spl-cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 30% 50%, rgba(34,197,94,.12) 0%, transparent 50%),
                    radial-gradient(circle at 80% 80%, rgba(34,197,94,.08) 0%, transparent 40%);
}

.spl-cta-section__inner {
  position: relative;
  z-index: 1;
}

.spl-cta-section__eyebrow {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--spl-accent);
  margin-bottom: 20px;
}

.spl-cta-section__title {
  font-size: clamp(26px, 4vw, 44px);
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
  letter-spacing: -.025em;
  margin: 0 0 16px;
}

.spl-cta-section__subtitle {
  font-size: clamp(15px, 1.8vw, 17px);
  color: #94a3b8;
  line-height: 1.65;
  margin: 0 0 48px;
  max-width: 480px;
  margin-inline: auto;
}

.spl-cta-section__buttons {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.spl-btn--line {
  background: #06c755;
  color: #fff;
  box-shadow: 0 4px 14px rgba(6,199,85,.35);
}
.spl-btn--line:hover {
  background: #05b44c;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(6,199,85,.4);
}

.spl-btn--dark-outline {
  background: transparent;
  color: #e2e8f0;
  border: 1.5px solid rgba(255,255,255,.18);
}
.spl-btn--dark-outline:hover {
  border-color: var(--spl-accent);
  color: var(--spl-accent);
  transform: translateY(-2px);
}

.spl-cta-section__reassurance {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  flex-wrap: wrap;
}

.spl-reassurance-item {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
  color: #64748b;
}

.spl-reassurance-item svg {
  color: var(--spl-accent);
}

/* ──────────────────────────────────────────────────────────
   FLOATING CHAT BUTTON
────────────────────────────────────────────────────────── */
.spl-float-chat {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10px;
}

.spl-float-chat__bubble {
  background: #06c755;
  color: #fff;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 24px rgba(6,199,85,.45);
  cursor: pointer;
  border: none;
  transition: transform var(--spl-transition), box-shadow var(--spl-transition);
  text-decoration: none;
}

.spl-float-chat__bubble:hover {
  transform: scale(1.12) translateY(-2px);
  box-shadow: 0 10px 36px rgba(6,199,85,.55);
}

.spl-float-chat__tooltip {
  background: var(--spl-text);
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  padding: 7px 14px;
  border-radius: 8px;
  white-space: nowrap;
  opacity: 0;
  transform: translateX(6px);
  transition: opacity var(--spl-transition), transform var(--spl-transition);
  pointer-events: none;
}

.spl-float-chat:hover .spl-float-chat__tooltip {
  opacity: 1;
  transform: translateX(0);
}

/* ──────────────────────────────────────────────────────────
   RESPONSIVE
────────────────────────────────────────────────────────── */
@media (max-width: 960px) {
  .spl-categories__grid { grid-template-columns: repeat(3, 1fr); }
  .spl-products__grid { grid-template-columns: repeat(2, 1fr); }
  .spl-problems__grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 640px) {
  .spl-categories__grid { grid-template-columns: repeat(2, 1fr); }
  .spl-products__grid { grid-template-columns: 1fr; }
  .spl-problems__grid { grid-template-columns: 1fr; }
  .spl-hero__cta-group { flex-direction: column; align-items: center; }
  .spl-hero__trust { gap: 14px; }
  .spl-search-box { flex-direction: column; align-items: stretch; padding: 10px 12px; }
  .spl-search-btn { border-radius: 8px; }
}

@media (max-width: 480px) {
  .spl-categories__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .spl-cat-card { padding: 20px 10px 18px; }
  .spl-cat-icon { width: 46px; height: 46px; font-size: 22px; }
